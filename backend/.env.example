# Viral Stick — Backend Environment
# Copie ce fichier en .env et remplis les clés

# ── IA Texte ──────────────────────────────────
# Gemini (recommandé — fallback principal)
GEMINI_API_KEY=votre_cle_gemini_ici

# Fallbacks optionnels
DEEPSEEK_API_KEY=votre_cle_deepseek_ici
MISTRAL_API_KEY=votre_cle_mistral_ici
OPENROUTER_API_KEY=votre_cle_openrouter_ici
OPENROUTER_MODEL=openai/gpt-4o-mini

# ── HuggingFace (texte + image) ───────────────
# Obligatoire pour la génération d'image.
# Obtenir un token gratuit sur https://huggingface.co/settings/tokens
# Droit requis : "Read" minimum (pas besoin de "Write")
HUGGING_FACE_KEY=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
HF_TOKEN=                        # alias accepté si HUGGING_FACE_KEY absent

# Modèle image par défaut (optionnel — le code utilise SDXL si absent)
# Options gratuites stables :
#   stabilityai/stable-diffusion-xl-base-1.0   ← recommandé
#   runwayml/stable-diffusion-v1-5
#   CompVis/stable-diffusion-v1-4
HUGGING_FACE_MODEL=stabilityai/stable-diffusion-xl-base-1.0

# Modèles texte HuggingFace (optionnels)
HUGGING_FACE_TEXT_MODEL=openai/gpt-oss-120b
HUGGING_FACE_CHAT_MODEL=zai-org/GLM-4.5V
HUGGING_FACE_PROMPT_MODEL=openai/gpt-oss-120b
HUGGING_FACE_REASONING_MODEL=openai/gpt-oss-120b

# ── Serveur ───────────────────────────────────
PORT=3000
